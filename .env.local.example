# ──────────────────────────────────────────────────────────────
# Mi Brújula de Salud — Variables de entorno
# Copiar este archivo como .env.local y completar los valores.
# NUNCA commitear .env.local con valores reales.
# ──────────────────────────────────────────────────────────────

# Supabase — obtener en https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App — URL base (sin trailing slash)
# En producción: https://tu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — protege el endpoint /api/cron/weekly-alerts
# Generar con: openssl rand -hex 32
# En Vercel: agregar en Settings → Environment Variables
CRON_SECRET=your-cron-secret-here
